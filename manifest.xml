<?xml version="1.0" encoding="UTF-8"?>
<OfficeApp xmlns="http://schemas.microsoft.com/office/appforoffice/1.1" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:bt="http://schemas.microsoft.com/office/officeappbasictypes/1.0" xmlns:mailappor="http://schemas.microsoft.com/office/mailappversionoverrides/1.0" xsi:type="MailApp">
    <Id>a1b2c3d4-5678-90ab-cdef-1234567890ab</Id>
    <Version>1.0.0.1</Version>
    <ProviderName>Grace ERP Consultancy</ProviderName>
    <DefaultLocale>en-US</DefaultLocale>
    <DisplayName DefaultValue="Odoo Custom Bridge" />
    <Description DefaultValue="Push emails to custom fields in Odoo." />
    <IconUrl DefaultValue="https://www.odoo.com/web/image/website/1/logo/Odoo" />
    <Hosts>
        <Host Name="Mailbox" />
    </Hosts>
    <Requirements>
        <Sets>
            <Set Name="Mailbox" MinVersion="1.1" />
        </Sets>
    </Requirements>
    <FormSettings>
        <Form xsi:type="ItemRead">
            <DesktopSettings>
                <SourceLocation DefaultValue="https://mintesnotshikur.github.io/odoo-outlook-addin/index.html" />
                <RequestedHeight>450</RequestedHeight>
            </DesktopSettings>
        </Form>
    </FormSettings>
    <Permissions>ReadItem</Permissions>
    <Rule xsi:type="RuleCollection" Mode="And">
        <Rule xsi:type="ItemIs" ItemType="Message" FormType="Read" />
    </Rule>

    <VersionOverrides xmlns="http://schemas.microsoft.com/office/mailappversionoverrides/1.0" xsi:type="VersionOverridesV1_0">
        <Hosts>
            <Host xsi:type="Mailbox">
                <DesktopFormFactor>
                    <FunctionFile resid="residFunctionFile" />
                    <ExtensionPoint xsi:type="MessageReadCommandSurface">
                        <OfficeTab id="TabDefault">
                            <Group id="grpOdoo">
                                <Label resid="residLabel" />
                                <Control xsi:type="Button" id="btnOdooPush">
                                    <Label resid="residLabel" />
                                    <Supertip>
                                        <Title resid="residLabel" />
                                        <Description DefaultValue="Open Odoo Bridge" />
                                    </Supertip>
                                    <Icon>
                                        <bt:Image size="16" resid="icon16" />
                                        <bt:Image size="32" resid="icon32" />
                                        <bt:Image size="80" resid="icon80" />
                                    </Icon>
                                    <Action xsi:type="ShowTaskpane">
                                        <SourceLocation resid="residTaskpaneUrl" />
                                    </Action>
                                </Control>
                            </Group>
                        </OfficeTab>
                    </ExtensionPoint>
                </DesktopFormFactor>
            </Host>
        </Hosts>
        <Resources>
            <bt:Images>
                <bt:Image id="icon16" DefaultValue="https://www.odoo.com/web/image/website/1/logo/Odoo" />
                <bt:Image id="icon32" DefaultValue="https://www.odoo.com/web/image/website/1/logo/Odoo" />
                <bt:Image id="icon80" DefaultValue="https://www.odoo.com/web/image/website/1/logo/Odoo" />
            </bt:Images>
            <bt:Urls>
                <bt:Url id="residFunctionFile" DefaultValue="https://mintesnotshikur.github.io/odoo-outlook-addin/index.html" />
                <bt:Url id="residTaskpaneUrl" DefaultValue="https://mintesnotshikur.github.io/odoo-outlook-addin/index.html" />
            </bt:Urls>
            <bt:ShortStrings>
                <bt:String id="residLabel" DefaultValue="Odoo Bridge" />
            </bt:ShortStrings>
        </Resources>
    </VersionOverrides>
</OfficeApp>
